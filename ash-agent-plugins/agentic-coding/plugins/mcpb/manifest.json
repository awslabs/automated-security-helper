{
  "manifest_version": "0.4",
  "name": "ash",
  "version": "1.0.0",
  "description": "Run ASH (Automated Security Helper) security scans via MCP — Bandit, Semgrep, detect-secrets, Checkov, Grype, Syft, and more across Python, JS, IaC, and dependencies.",
  "long_description": "Run ASH (Automated Security Helper) security scans directly in Claude\nDesktop. Bundles uvx-based ASH MCP server invocation; no separate\ninstall step required beyond having uvx on the user's PATH.\n",
  "author": {
    "name": "AWS Labs",
    "url": "https://github.com/awslabs/automated-security-helper"
  },
  "homepage": "https://github.com/awslabs/automated-security-helper",
  "repository": {
    "type": "git",
    "url": "https://github.com/awslabs/automated-security-helper"
  },
  "license": "Apache-2.0",
  "keywords": [
    "security-scan",
    "vulnerability-scan",
    "ash",
    "sast",
    "sca",
    "checkov",
    "bandit",
    "semgrep",
    "grype"
  ],
  "server": {
    "type": "binary",
    "entry_point": "uvx",
    "mcp_config": {
      "command": "uvx",
      "args": [
        "--from=git+https://github.com/awslabs/automated-security-helper@v3.4.0",
        "ash",
        "mcp"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    }
  },
  "compatibility": {
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
